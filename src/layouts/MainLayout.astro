---
const { title } = Astro.props;
---
<html lang="he" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title} | תוכנית בנייה בעץ</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Assistant:wght@400;700;800&display=swap" rel="stylesheet">
    <style>body { font-family: 'Assistant', sans-serif; }</style>
</head>
<body class="bg-stone-50 text-stone-900">
    <header class="bg-orange-950 text-white p-5 shadow-xl text-center">
        <h1 class="text-2xl font-bold">תוכנית בנייה בעץ 🔨</h1>
    </header>
    <main><slot /></main>
    <footer class="bg-stone-900 text-stone-500 p-10 mt-20 text-center">
        <p>© 2024 DIY Wood Plans</p>
    </footer>
</body>
</html>
