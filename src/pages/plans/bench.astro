---
import MainLayout from '../../layouts/MainLayout.astro';
export const frontmatter = { 
    title: "ספסל גינה קלאסי", 
    description: "ספסל עץ יציב, חזק וקל לבנייה מלוחות אורן סטנדרטיים." 
};
---
<MainLayout title={frontmatter.title}>
    <article class="max-w-4xl mx-auto py-16 px-6 bg-white my-10 shadow-2xl rounded-3xl border-t-8 border-orange-800 text-right">
        <h1 class="text-5xl font-black mb-6 text-stone-900">{frontmatter.title}</h1>
        <div class="p-6 bg-orange-50 rounded-2xl mb-10 border-r-4 border-orange-500 italic text-orange-900 text-xl">
            זהו פרויקט מושלם לסוף שבוע. הוא דורש כלים בסיסיים בלבד ומספק תוצאה מרשימה ועמידה.
        </div>
        
        <h2 class="text-3xl font-bold mb-8 text-stone-800 border-b pb-2">מה נצטרך?</h2>
        <ul class="space-y-4 text-xl mb-12">
            <li class="flex items-center gap-3">🔨 3 לוחות אורן 2x4 באורך 2.4 מטר</li>
            <li class="flex items-center gap-3">🔨 חבילת ברגי עץ 60 מ"מ חיצוניים</li>
            <li class="flex items-center gap-3">🔨 דבק נגרים עמיד במים</li>
        </ul>
        
        <h2 class="text-3xl font-bold mb-8 text-stone-800 border-b pb-2">שלבי העבודה</h2>
        <p class="text-xl leading-relaxed text-gray-700">הוראות החיתוך וההרכבה המלאות יועלו לכאן בקרוב!</p>
    </article>
</MainLayout>
