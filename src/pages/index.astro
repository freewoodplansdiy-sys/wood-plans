---
import MainLayout from '../layouts/MainLayout.astro';
const plans = await Astro.glob('./plans/*.astro');
---
<MainLayout title="תוכניות בנייה בחינם">
    <section class="bg-orange-900 text-white py-24 text-center">
        <h1 class="text-6xl font-black mb-6 tracking-tighter">בנו זאת בעצמכם.</h1>
        <p class="text-2xl opacity-90 max-w-2xl mx-auto leading-relaxed px-4">תוכניות נגרות מקצועיות בחינם, שלב אחר שלב, למתחילים ולמתקדמים.</p>
    </section>
    
    <main class="container mx-auto py-20 px-4">
        <h2 class="text-3xl font-bold mb-12 border-r-8 border-orange-600 pr-4">הפרויקטים שלנו</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12">
            {plans.map(plan => (
                <a href={plan.url} class="group bg-white rounded-3xl shadow-lg overflow-hidden border border-stone-200 transition hover:shadow-2xl">
                    <div class="h-56 bg-stone-200 flex items-center justify-center text-6xl group-hover:scale-110 transition-transform">🪵</div>
                    <div class="p-8 text-right">
                        <h3 class="text-2xl font-bold text-stone-800">{plan.frontmatter.title}</h3>
                        <p class="text-stone-500 mt-3 leading-relaxed">{plan.frontmatter.description}</p>
                        <div class="mt-6 text-orange-700 font-bold flex items-center gap-2">
                             לתוכנית המלאה <span>←</span>
                        </div>
                    </div>
                </a>
            ))}
        </div>
    </main>
</MainLayout>
