---
import MainLayout from '../layouts/MainLayout.astro';
const plans = await Astro.glob('./plans/*.astro');
---
<MainLayout title="דף הבית">
    <section class="bg-orange-900 text-white py-16 text-center">
        <h1 class="text-5xl font-black mb-4 italic leading-tight">בנו זאת בעצמכם</h1>
        <p class="text-xl opacity-80">תוכניות נגרות בחינם, פשוטות ומקצועיות</p>
    </section>
    <main class="container mx-auto py-16 px-4">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
            {plans.map(plan => (
                <a href={plan.url} class="bg-white rounded-3xl shadow-xl p-6 border border-stone-200 block transition hover:scale-105 text-right">
                    <h3 class="text-xl font-bold text-stone-800">{plan.frontmatter.title}</h3>
                    <p class="text-stone-500 mt-2 text-sm">{plan.frontmatter.description}</p>
                    <span class="text-orange-700 font-bold mt-4 block text-sm">לתוכנית המלאה ←</span>
                </a>
            ))}
        </div>
    </main>
</MainLayout>
